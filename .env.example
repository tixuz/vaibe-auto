# ─── LLM brain — pick ONE (or set several, switch via --mode) ───────────────
# Mode: claude (paid)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Mode: zero (local, free) — LM Studio or Ollama, OpenAI-compatible endpoint
# LM Studio exposes BOTH /v1/chat/completions (used here) and /v1/responses
# (newer OpenAI spec). We use chat/completions for max compatibility.
LMSTUDIO_URL=http://localhost:1234/v1/chat/completions
# Pick ONE model name that you've loaded in LM Studio (exact model id):
#   miniqwen                    — our shorthand for qwen2.5-7b-instruct
#   google/gemma-4-e4b          — Google Gemma (small, fast)
#   qwen2.5-coder-7b-instruct   — better for code-heavy reasoning
LMSTUDIO_MODEL=miniqwen
# LM Studio ignores auth but some reverse proxies need it — leave empty normally
LMSTUDIO_API_KEY=

# Mode: openrouter (hosted; many :free models; some paid premium)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-chat-v3:free
# Optional attribution headers (shown on openrouter.ai/activity)
OPENROUTER_REFERER=https://github.com/tixuz/vaibe-auto
OPENROUTER_TITLE=vaibe-auto

# ── video rendering — pick ONE provider (or set both, switch via --provider) ──
# Provider 1: fal.ai (default)
FAL_KEY=fal-...

# Provider 2: Enhancor.ai — WARNING: API requires paid Creator subscription
# ($459/yr, or $344 first year with SAVE25). Not pay-as-you-go like fal.ai.
# Only enable if you've committed to the subscription. See GETTING-STARTED.md.
ENHANCOR_API_KEY=
ENHANCOR_PROMO=SAVE25

# ── optional: asset source (leave empty for local folders) ──
# GDRIVE_MOUNT=/Users/you/GoogleDrive/vaibe-auto-assets
